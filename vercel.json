{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/web/dist"
      }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/leads(.*)", "dest": "/backend/main.py" },
    { "src": "/metrics(.*)", "dest": "/backend/main.py" },
    { "src": "/simulate(.*)", "dest": "/backend/main.py" },
    { "src": "/docs(.*)", "dest": "/backend/main.py" },
    { "src": "/openapi.json", "dest": "/backend/main.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "backend/main.py": {
      "includeFiles": "ml/data/**"
    }
  }
}
